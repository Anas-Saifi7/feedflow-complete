{
  "expo": {
    "name": "FeedFlow",
    "slug": "feedflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.feedflow.app"
    },
    "android": {
      "package": "com.feedflow.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "feedflow",
    "extra": {
      "apiUrl": "https://feedflow-complete.onrender.com"
    }
  }
}